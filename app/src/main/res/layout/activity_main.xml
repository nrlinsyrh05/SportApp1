<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏟️ Sport Venue Finder"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#009688"
        android:padding="16dp"
        android:gravity="center"/>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnSearchVenue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔍 Search"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnBookVenue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 Book"
            android:backgroundTint="#009688"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnMap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗺️ Map"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnBookingHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Bookings"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

    </LinearLayout>

    <!-- Welcome Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👋 Book your favorite sports venue!"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="16dp"/>

    <!-- Quick Book Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏸 Quick Book"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#009688"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book a venue instantly"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp"/>

        <Button
            android:id="@+id/btnQuickBook"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📅 Book Now"
            android:backgroundTint="#009688"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"
            android:textSize="16sp"/>

    </LinearLayout>

    <!-- Status Message -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="8dp"/>

    <!-- Bottom Buttons - FIXED: Changed layout_marginTop to a proper dimension -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤 Profile"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚪 Logout"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_margin="4dp"/>

    </LinearLayout>

</LinearLayout>