<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Full Screen Map -->
    <fragment
        android:id="@+id/map_navigation"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top Header - App Theme Color -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="32dp"
        android:background="@color/primary_color"
        android:elevation="4dp">

        <!-- Top Row: Back, Title, Voice Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="0dp"
                android:background="@drawable/rounded_button"
                android:elevation="4dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Navigation"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <Button
                android:id="@+id/btnVoiceToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="🔊"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="0dp"
                android:background="@drawable/rounded_button"
                android:elevation="4dp"/>

        </LinearLayout>

        <!-- Destination Name -->
        <TextView
            android:id="@+id/tvDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stadium A"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <!-- ETA, Distance, Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvHeaderDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 min"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvHeaderDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.5 km"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="#FFFFFF"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:57 PM GMT+8"
                android:textColor="#E0E0E0"
                android:textSize="14sp"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Sheet -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true">

        <androidx.cardview.widget.CardView
            android:id="@+id/bottomSheetNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:behavior_peekHeight="180dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@android:color/white">

                <!-- Drag Handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="#C0C0C0"
                    android:layout_marginBottom="12dp"
                    android:alpha="0.5"/>

                <!-- Current Instruction -->
                <LinearLayout
                    android:id="@+id/llNavigationControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="#F0F8FF"
                    android:padding="14dp"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp">

                    <TextView
                        android:id="@+id/tvInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Head southeast"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvRoadName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Persiaran Tun Arshad A"
                        android:textSize="15sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tvStepDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.5 km"
                            android:textSize="14sp"
                            android:textColor="#555555"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textSize="14sp"
                            android:textColor="#555555"/>

                        <TextView
                            android:id="@+id/tvStepDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 min"
                            android:textSize="14sp"
                            android:textColor="#555555"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Navigation Controls -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnStartNavigation"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="START"
                        android:backgroundTint="@color/primary_color"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnEndNavigation"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="END"
                        android:backgroundTint="#F44336"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- Steps List -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Directions"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSteps"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</RelativeLayout>