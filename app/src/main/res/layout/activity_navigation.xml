<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#009688">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigation"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To: Destination"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <!-- Header Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvHeaderDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.5 km"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvHeaderDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · 7 min"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="· 9:57 PM GMT+8"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Map -->
    <fragment
        android:id="@+id/map_navigation"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bottom Sheet -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0">

        <androidx.cardview.widget.CardView
            android:id="@+id/bottomSheetNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:behavior_peekHeight="180dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@android:color/white">

                <!-- Drag Handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="#C0C0C0"
                    android:layout_marginBottom="12dp"/>

                <!-- Bottom Sheet Info Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance"
                            android:textSize="12sp"
                            android:textColor="#666666"/>

                        <TextView
                            android:id="@+id/tvBottomDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 km"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#009688"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textSize="12sp"
                            android:textColor="#666666"/>

                        <TextView
                            android:id="@+id/tvBottomDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 min"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#009688"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStartNavigation"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Start"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnEndNavigation"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="End"
                        android:backgroundTint="#F44336"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Current Instruction -->
                <LinearLayout
                    android:id="@+id/llNavigationControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:background="#F0F8FF"
                    android:padding="12dp"
                    android:elevation="4dp">

                    <TextView
                        android:id="@+id/tvInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Head southeast"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvNextStep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Then · 3.5 km"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Steps List -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn-by-turn directions"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSteps"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</LinearLayout>